generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Level {
  L3
  L4
  L5
  L6
  SDE_I
  SDE_II
  SDE_III
  STAFF
  PRINCIPAL
  IC4
  IC5
}

enum Currency {
  INR
  USD
  GBP
  EUR
}

enum Source {
  CONTRIBUTOR
  SCRAPED
  AI_INFERRED
}

model Company {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  slug            String   @unique
  normalized_name String
  industry        String
  headquarters    String
  founded_year    Int?
  headcount_range String?
  salaries        Salary[]
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([normalized_name])
  @@map("companies")
}

model Salary {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id         String   @db.Uuid
  company            Company  @relation(fields: [company_id], references: [id])
  role               String
  level              Level
  location           String
  currency           Currency @default(INR)
  experience_years   Int
  base_salary        BigInt
  bonus              BigInt   @default(0)
  stock              BigInt   @default(0)
  total_compensation BigInt
  source             Source   @default(CONTRIBUTOR)
  confidence_score   Decimal  @db.Decimal(3, 2) @default(0.5)
  is_verified        Boolean  @default(false)
  submitted_at       DateTime @default(now())
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@index([company_id, level, location])
  @@index([total_compensation])
  @@index([submitted_at])
  @@index([location, level])
  @@map("salaries")
}
